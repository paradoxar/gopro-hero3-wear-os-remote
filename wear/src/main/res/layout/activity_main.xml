<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout for the GoPro Remote Wear OS application.
    This screen provides controls for power, recording, and displays the camera's battery status.
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:padding="8dp">

    <!-- hero3_status : Triggers a status update from the camera -->
    <LinearLayout
        android:id="@+id/hero3_status"
        android:layout_width="50dp"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/button_stack"
        android:layout_centerVertical="true"
        android:layout_marginEnd="5dp"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/connection_dot"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_wifi_24"
            android:tint="#555555"
            android:contentDescription="HERO3 WiFi status"
            tools:ignore="HardcodedText,UseAppTint,VisualLintBounds" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H\n3\n\nW\ni\nF\ni"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            tools:ignore="HardcodedText" />

    </LinearLayout>

    <!-- Control Stack: Power and Recording buttons -->
    <LinearLayout
        android:id="@+id/button_stack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <Button
            android:id="@+id/watch_on"
            android:layout_width="85dp"
            android:layout_height="40dp"
            android:background="@drawable/rounded50dp_button"
            android:backgroundTint="#333333"
            android:gravity="center"
            android:text="Pwr On"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText,TouchTargetSizeCheck,VisualLintBounds" />

        <Button
            android:id="@+id/watch_off"
            android:layout_width="85dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded50dp_button"
            android:backgroundTint="#333333"
            android:gravity="center"
            android:text="Pwr Off"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            tools:ignore="HardcodedText,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/watch_start"
            android:layout_width="85dp"
            android:layout_height="42dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded25dp_button"
            android:backgroundTint="#333333"
            android:gravity="center"
            android:text="REC"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:ignore="HardcodedText,TouchTargetSizeCheck" />

        <Button
            android:id="@+id/watch_stop"
            android:layout_width="85dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded25dp_button"
            android:backgroundTint="#333333"
            android:gravity="center"
            android:text="STOP"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            tools:ignore="HardcodedText,TouchTargetSizeCheck,VisualLintBounds" />
    </LinearLayout>

    <!-- Battery Indicator: Displays the GoPro's battery level using segmented bars -->
    <LinearLayout
        android:id="@+id/battery_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_toEndOf="@id/button_stack"
        android:layout_centerVertical="true"
        android:layout_marginStart="20dp">

        <TextView
            android:id="@+id/battery_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BAT"
            android:textColor="#AAAAAA"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            tools:ignore="HardcodedText,SmallSp" />

        <View
            android:id="@+id/battery_bar_3"
            android:layout_width="24dp"
            android:layout_height="10dp"
            android:background="#333333"
            android:layout_marginBottom="3dp"
            tools:ignore="VisualLintWearMargin,VisualLintBounds" />

        <View
            android:id="@+id/battery_bar_2"
            android:layout_width="24dp"
            android:layout_height="10dp"
            android:background="#333333"
            android:layout_marginBottom="3dp"
            tools:ignore="VisualLintBounds,VisualLintWearMargin" />

        <View
            android:id="@+id/battery_bar_1"
            android:layout_width="24dp"
            android:layout_height="10dp"
            android:background="#333333"
            tools:ignore="VisualLintWearMargin,VisualLintBounds" />

    </LinearLayout>
</RelativeLayout>